{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,

    // Kept lenient on purpose: while you are experimenting in class, an
    // unused variable should not stop the app from running.
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src"]
}
